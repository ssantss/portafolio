---
import presentation from "@/data/presentation";

// FAB de contacto discreto pero siempre presente. Neutro/monocromo para no
// romper la paleta del sitio; abre WhatsApp con un mensaje pre-rellenado que
// baja la fricción y filtra leads serios.
const phone = presentation.phone.replace(/[^0-9]/g, "");
const message = "Hola Santiago, vi tu portafolio y me gustaría hablar sobre un proyecto.";
const href = `https://wa.me/${phone}?text=${encodeURIComponent(message)}`;
---

<a
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  aria-label="Contactar a Santiago por WhatsApp"
  class="wa-fab group fixed bottom-6 right-6 z-50 flex flex-col items-end gap-2 md:bottom-8 md:right-8"
>
  <span
    class="wa-tooltip pointer-events-none rounded-full border border-neutral-700 bg-black/90 px-4 py-2 text-sm font-medium text-neutral-100 opacity-0 shadow-lg backdrop-blur transition-opacity duration-300 group-hover:opacity-100"
  >
    Hablemos
  </span>
  <span
    class="flex h-12 w-12 items-center justify-center rounded-full border border-neutral-700 bg-black/90 text-neutral-100 shadow-lg backdrop-blur transition-all duration-300 group-hover:scale-105 group-hover:border-neutral-400 md:h-14 md:w-14"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      fill="currentColor"
      class="h-6 w-6 text-[#25D366] md:h-7 md:w-7"
      aria-hidden="true"
    >
      <path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448l-6.305 1.654zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648 3.742-.981zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"></path>
    </svg>
  </span>
</a>

<style>
  /* Aparición suave una sola vez al cargar — presente sin llamar la atención. */
  .wa-fab {
    animation: wa-fab-in 0.5s ease-out 0.6s both;
  }

  @keyframes wa-fab-in {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* El tooltip se asoma solo al cargar, se queda un momento y se desvanece.
     Sin fill-mode, así al terminar vuelve a su estado base (opacity-0) y el
     group-hover lo sigue revelando con normalidad. */
  .wa-tooltip {
    animation: wa-tip-peek 4s ease-in-out 1.2s;
  }

  @keyframes wa-tip-peek {
    0% {
      opacity: 0;
      transform: translateY(6px);
    }
    12%,
    70% {
      opacity: 1;
      transform: translateY(0);
    }
    100% {
      opacity: 0;
      transform: translateY(6px);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .wa-fab,
    .wa-tooltip {
      animation: none;
    }
  }
</style>
