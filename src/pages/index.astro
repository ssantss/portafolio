---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/terminal/Header.astro";
import Hero from "@/components/terminal/Hero.astro";
import Stack from "@/components/terminal/Stack.astro";
import Projects from "@/components/terminal/Projects.astro";
import Contact from "@/components/terminal/Contact.astro";
import Footer from "@/components/terminal/Footer.astro";
---

<Layout>
  <div class="p-5 md:p-10">
    <main
      class="mx-auto max-w-[1080px] overflow-hidden rounded-[8px] border border-line bg-bg text-text shadow-[0_24px_60px_rgba(0,0,0,0.5)]"
    >
      <Header />
      <Hero />
      <Stack />
      <Projects />
      <Contact />
      <Footer />
    </main>
  </div>
</Layout>
